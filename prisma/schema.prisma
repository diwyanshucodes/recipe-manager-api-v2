generator client {
  provider = "prisma-client-js"
  // output   = "../node_modules/@prisma/client"
}
datasource db {
  provider = "postgresql"
}

model User {
  id Int @id @default(autoincrement())
  email String @unique
  password_hash String
  created_at DateTime @default(now())
  recipes Recipe[]
}

model Recipe {
  id Int @id @default(autoincrement())
  title String
  description String?
  prep_time Int?
  category String
  image_url   String? 
  created_at DateTime @default(now())
  user_id Int // FK column
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  ingredients Ingredient[]
  updated_at DateTime @updatedAt   // Prisma auto-updates this on every write
  @@index([user_id])
}

model Ingredient {
  id Int @id @default(autoincrement())
  name String
  amount String
  unit String
  recipe_id Int
  created_at DateTime @default(now())
  recipe Recipe @relation(fields: [recipe_id], references: [id], onDelete: Cascade)
  @@index([recipe_id])
}